{
  "info": {
    "name": "AssurLink API - MVP",
    "_postman_id": "assurlink-mvp",
    "description": "Postman collection for AssurLink Sénégal MVP endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{ \"username\": \"admin@example.com\", \"password\": \"secret\" }" },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "auth", "login" ] }
      }
    },
    {
      "name": "Create Quote",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"product_id\": \"prod-1\", \"customer\": { \"name\": \"M. Dupont\" } }" },
        "url": { "raw": "{{baseUrl}}/organizations/{{orgId}}/quotes", "host": [ "{{baseUrl}}" ], "path": [ "organizations", "{{orgId}}", "quotes" ] }
      }
    }
  ]
}
